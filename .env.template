# Bluesky Post Explainer — Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# Never commit the .env file to version control.
#
# Usage:
#   cp .env.template .env
#   # Edit .env with your credentials

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Primary model — used for all text and vision calls. Default: gpt-4o
OPENAI_MODEL=gpt-4o

# Fallback model — used when the primary exceeds its context window. Default: gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ─── Bluesky Authentication ───────────────────────────────────────────────────
# Your Bluesky handle (e.g. yourname.bsky.social)
# Used for authenticated API access to fetch posts and image blobs.
BLUESKY_HANDLE=

# App password — create one at: https://bsky.app/settings/app-passwords
# Do NOT use your main account password here.
BLUESKY_APP_PASSWORD=
